# Wavelength — environment variables
# Copy to `.env.local` for local development (Next.js loads this automatically).

# Required — Aiven Postgres connection string
# Example: postgres://user:password@your-host.aivencloud.com:12345/defaultdb?sslmode=require
DATABASE_URL=

# Required for Worry Doll chat (OpenAI via Vercel AI SDK)
# Get from: https://platform.openai.com/api-keys
OPENAI_API_KEY=

# Optional — set automatically by Next.js
# NODE_ENV=development
